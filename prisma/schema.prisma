// prisma/schema.prisma
// Prisma 7: NO url/directUrl here — those go in prisma.config.ts

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String    @id @default(cuid())
  name      String
  phone     String
  category  String
  status    String    @default("pending")
  batchId   String
  sentAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([batchId])
  @@index([status])
}

model Batch {
  id         String   @id @default(cuid())
  fileName   String
  totalCount Int
  sentCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
